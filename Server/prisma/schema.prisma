generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// -----------------------------------

enum PrePoStatus {
  PREPO_DRAFT
  PREPO_REQUESTED
  PREPO_APPROVED
  PREPO_REJECTED
  PO_GENERATED
}

model PrePo {
  id String @id @default(uuid())

  poId          String?
  poNumber      String?

  purchaseOrder PurchaseOrder? @relation(fields: [poId], references: [id])


  vendorId String?
  vendor   Vendor? @relation(fields: [vendorId], references: [id])

  status PrePoStatus @default(PREPO_DRAFT)

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  createdBy       String?
  prePO_CreatedBy User?        @relation("PrePO_CreatedByUser", fields: [createdBy], references: [id])
  updatedBy       String?
  prePO_UpdatedBy User?        @relation("PrePO_UpdatedByUser", fields: [updatedBy], references: [id])
  prePoItems      PrePoItems[]
}

model PrePoItems {
  id String @id @default(uuid())

  prePoId String
  prePo   PrePo  @relation(fields: [prePoId], references: [id])

  itemId     String?
  itemSource String?
  itemName   String?
  quantity   Decimal @db.Decimal(18, 4)
  unit       String?

  rate Decimal @db.Decimal(12, 4)

  createdAt  DateTime  @default(now())
  updatedAt DateTime? @updatedAt
}

// ------------------------------------

model User {
  id                        String                       @id @default(uuid())
  name                      String?
  email                     String?                      @unique
  contact                   String?
  password                  String?
  roleId                    String?
  block                     String?
  district                  String?
  state                     String?
  isActive                  Boolean?
  refreshToken              String?
  createdAt                 DateTime                     @default(now())
  updatedAt                 DateTime                     @default(now()) @updatedAt
  warehouseId               String?
  allotedCompany            Json?
  BankDetail                BankDetail[]
  Company                   Company[]
  damagedStocksCreated      DamagedStock[]               @relation("Damaged_Stock_CreatedBy")
  damagedStocksUpdated      DamagedStock[]               @relation("Damaged_Stock_UpdatedBy")
  debitNotes                DebitNote[]
  issuedItemsByUser         DirectItemIssue[]            @relation("IssuedByUser")
  issuedItemsToUser         DirectItemIssue[]            @relation("IssuedToUser")
  updatedByUser_DirectIssue DirectItemIssue[]            @relation("UpdatedByUser_DirectIssue")
  assembleStockReceives     Disassemble_Reusable_Items[] @relation("AssembleEmployee")
  disassembleTasks          Disassemble_Reusable_Items[] @relation("DisassembleEmployee")
  infraItemsCreated         InfraMaterial[]              @relation("InfraItemCreatedByUser")
  infraItemsUpdated         InfraMaterial[]              @relation("InfroItemUpdatedByUser")
  updatedItems              ItemRawMaterial[]            @relation("UserUpdates")
  approvedItemRequests      ItemRequestData[]            @relation("ApprovedByUser")
  declinedItemRequests      ItemRequestData[]            @relation("DeclinedByUser")
  requestedItemRequests     ItemRequestData[]            @relation("RequestedByUser")
  updatedItemRequests       ItemRequestData[]            @relation("UpdatedByUser")
  itemUsage                 ItemUsage[]
  adminApprovedPayments     Payment[]                    @relation("approvedBy_Admin")
  paymentsCreated           Payment[]                    @relation("paymentCreatedBy")
  docApprovedPayments       Payment[]                    @relation("doc_ApprovedBy")
  paymentRejectedBy         Payment[]                    @relation("payment_RejectedBy")
  paymentsRequested         Payment[]                    @relation("payment_RequestedBy")
  paymentTransferred        Payment[]                    @relation("payment_TransferredBy")
  productionLogs            ProductionLog[]
  followUpCreatedBy         PurchaseFollowUp[]           @relation("followUp_CreatedBy")
  followUpUpdatedBy         PurchaseFollowUp[]           @relation("followUp_UpdatedBy")
  PurchaseOrder             PurchaseOrder[]
  PurchaseOrderReceipt      PurchaseOrderReceipt[]
  rawMaterialCreated        RawMaterial[]                @relation("ItemCreatedByUser")
  rawMaterialUpdated        RawMaterial[]                @relation("ItemUpdatedByUser")
  services                  ServiceRecord[]
  createdServiceProcess     Service_Process_Record[]     @relation("CreatedByUser")
  updatedServiceProcess     Service_Process_Record[]     @relation("UpdatedByUser")
  stageActivity             StageActivity[]
  stocks                    StockMovement[]
  stockMovementBatch        StockMovementBatch[]
  termsCreatedBy            Terms_Conditions[]           @relation("TermsCreatedBy")
  termsUpdatedBy            Terms_Conditions[]           @relation("TermsUpdatedBy")
  toolsCreatedBy            ToolsEquipments[]            @relation("ToolsCreatedByUser")
  toolsUpdatedBy            ToolsEquipments[]            @relation("ToolsUpdatedByUser")
  role                      Role?                        @relation(fields: [roleId], references: [id])
  userItemStock             UserItemStock[]
  Vendor                    Vendor[]
  invoiceCreated            VendorInvoices[]             @relation("invoice_CreatedBy")
  invoiceUpdated            VendorInvoices[]             @relation("invoice_UpdatedBy")
  prePO_Created             PrePo[]                      @relation("PrePO_CreatedByUser")
  prePO_Updated             PrePo[]                      @relation("PrePO_UpdatedByUser")

  @@index([roleId], map: "User_roleId_fkey")
}

model Role {
  id        String   @id @default(uuid())
  name      String?  @unique
  createdAt DateTime @default(now())
  users     User[]
}

model Warehouse {
  id        String   @id @default(uuid())
  name      String?  @unique
  state     String?
  createdAt DateTime @default(now())
}

model Item {
  id                 String               @id @default(uuid())
  name               String?              @unique
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  rawMaterials       ItemRawMaterial[]
  manufacturingUsage ManufacturingUsage[]
  productItemMap     Product_Item_Map[]
  productionLogs     ProductionLog[]
}

model RawMaterial {
  id                  String               @id @default(uuid())
  name                String?              @unique
  stock               Float?
  unit                String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  isUsed              Boolean?             @default(true)
  createdBy           String?
  minQty              Float?
  updatedBy           String?
  conversionFactor    Float?
  conversionUnit      String?
  description         String?
  hsnCode             String?
  ItemRawMaterial     ItemRawMaterial[]
  itemUsage           ItemUsage[]
  manufacturingUsages ManufacturingUsage[]
  createdByUser       User?                @relation("ItemCreatedByUser", fields: [createdBy], references: [id])
  updatedByUser       User?                @relation("ItemUpdatedByUser", fields: [updatedBy], references: [id])
  serviceUsages       ServiceUsage[]
  stageRawMaterial    StageRawMaterial[]
  stockMovements      StockMovement[]
  userItemStock       UserItemStock[]
  warehouseStock      WarehouseStock[]

  @@index([createdBy], map: "RawMaterial_createdBy_fkey")
  @@index([updatedBy], map: "RawMaterial_updatedBy_fkey")
}

model ItemRawMaterial {
  id            String       @id @default(uuid())
  itemId        String?
  rawMaterialId String?
  quantity      Float?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  updatedBy     String?
  itemModelId   String?
  item          Item?        @relation(fields: [itemId], references: [id])
  itemModel     Item_Model?  @relation(fields: [itemModelId], references: [id])
  rawMaterial   RawMaterial? @relation(fields: [rawMaterialId], references: [id])
  user          User?        @relation("UserUpdates", fields: [updatedBy], references: [id])

  @@unique([itemId, rawMaterialId])
  @@index([rawMaterialId], map: "ItemRawMaterial_rawMaterialId_fkey")
  @@index([itemModelId], map: "ItemRawMaterial_itemModelId_fkey")
  @@index([updatedBy], map: "ItemRawMaterial_updatedBy_fkey")
}

model StageRawMaterial {
  id            String       @id @default(uuid())
  stageId       String?
  rawMaterialId String?
  createdAt     DateTime?    @default(now())
  updatedAt     DateTime?    @updatedAt
  rawMaterial   RawMaterial? @relation(fields: [rawMaterialId], references: [id])
  stage         Stage?       @relation(fields: [stageId], references: [id])

  @@unique([stageId, rawMaterialId])
  @@index([rawMaterialId], map: "StageRawMaterial_rawMaterialId_fkey")
}

model WarehouseStock {
  id              String           @id @default(uuid())
  warehouseId     String?
  rawMaterialId   String?
  quantity        Float?           @default(0)
  unit            String?
  isUsed          Boolean?         @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  damagedQty      Float?           @default(0)
  infraItemId     String?
  itemType        ItemCategory?
  toolEquipmentId String?
  itemId          String?
  infraItem       InfraMaterial?   @relation(fields: [infraItemId], references: [id])
  rawMaterial     RawMaterial?     @relation(fields: [rawMaterialId], references: [id])
  toolsEquipments ToolsEquipments? @relation(fields: [toolEquipmentId], references: [id])

  @@unique([warehouseId, rawMaterialId])
  @@unique([warehouseId, infraItemId])
  @@unique([warehouseId, toolEquipmentId])
  @@index([warehouseId])
  @@index([infraItemId], map: "WarehouseStock_infraItemId_fkey")
  @@index([rawMaterialId], map: "WarehouseStock_rawMaterialId_fkey")
  @@index([toolEquipmentId], map: "WarehouseStock_toolEquipmentId_fkey")
}

model StockMovementBatch {
  id            String          @id @default(uuid())
  billPhotos    Json?
  createdAt     DateTime?       @default(now())
  createdBy     String?
  stockMovement StockMovement[]
  user          User?           @relation(fields: [createdBy], references: [id])

  @@index([createdBy], map: "StockMovementBatch_createdBy_fkey")
}

model StockMovement {
  id              String              @id @default(uuid())
  rawMaterialId   String?
  userId          String?
  warehouseId     String?
  quantity        Float?
  unit            String?
  type            String?
  timestamp       DateTime            @default(now())
  batchId         String?
  infraItemId     String?
  toolEquipmentId String?
  itemId          String?
  itemType        ItemCategory?
  batch           StockMovementBatch? @relation(fields: [batchId], references: [id])
  infraItem       InfraMaterial?      @relation(fields: [infraItemId], references: [id])
  rawMaterial     RawMaterial?        @relation(fields: [rawMaterialId], references: [id])
  toolsEquipments ToolsEquipments?    @relation(fields: [toolEquipmentId], references: [id])
  user            User?               @relation(fields: [userId], references: [id])

  @@index([rawMaterialId], map: "StockMovement_rawMaterialId_fkey")
  @@index([warehouseId], map: "StockMovement_warehouseId_fkey")
  @@index([batchId], map: "StockMovement_batchId_fkey")
  @@index([infraItemId], map: "StockMovement_infraItemId_fkey")
  @@index([toolEquipmentId], map: "StockMovement_toolEquipmentId_fkey")
  @@index([userId], map: "StockMovement_userId_fkey")
}

model ManufacturingUsage {
  id                String       @id @default(uuid())
  itemId            String?
  rawMaterialId     String?
  quantityUsed      Float?
  unit              String?
  manufacturingDate DateTime     @default(now())
  item              Item?        @relation(fields: [itemId], references: [id])
  rawMaterial       RawMaterial? @relation(fields: [rawMaterialId], references: [id])

  @@index([itemId], map: "ManufacturingUsage_itemId_fkey")
  @@index([rawMaterialId], map: "ManufacturingUsage_rawMaterialId_fkey")
}

model ProductionLog {
  id                String   @id @default(uuid())
  itemId            String
  subItem           String
  quantityProduced  Int
  manufacturingDate DateTime @default(now())
  userId            String
  item              Item     @relation(fields: [itemId], references: [id])
  user              User     @relation(fields: [userId], references: [id])

  @@index([itemId], map: "ProductionLog_itemId_fkey")
  @@index([userId], map: "ProductionLog_userId_fkey")
}

model ServiceRecord {
  id                 String         @id @default(uuid())
  item               String?
  subItem            String?
  quantity           Float?
  serialNumber       String?
  faultAnalysis      Json?
  isRepaired         Boolean?
  repairedRejectedBy String?
  remarks            String?
  repairedParts      Json?
  userId             String
  servicedAt         DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  initialRCA         Json?
  user               User           @relation(fields: [userId], references: [id])
  serviceUsages      ServiceUsage[]

  @@index([serialNumber])
  @@index([userId])
}

model ServiceUsage {
  id            String        @id @default(uuid())
  serviceId     String
  rawMaterialId String?
  quantityUsed  Float?
  unit          String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  rawMaterial   RawMaterial?  @relation(fields: [rawMaterialId], references: [id])
  service       ServiceRecord @relation(fields: [serviceId], references: [id])

  @@index([serviceId], map: "ServiceUsage_serviceId_fkey")
  @@index([rawMaterialId], map: "ServiceUsage_rawMaterialId_fkey")
}

model Unit {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model Stage {
  id                               String                   @id @default(uuid())
  name                             String                   @unique
  description                      String?
  createdAt                        DateTime                 @default(now())
  updatedAt                        DateTime                 @updatedAt
  failureRedirectStage             FailureRedirect[]
  itemTypeStage                    ItemType_Stage[]
  serviceProcessInitialStage       Service_Process_Record[] @relation("InitialStage")
  serviceProcessRestartedFromStage Service_Process_Record[] @relation("RestartedFrom")
  serviceProcess                   Service_Process_Record[]
  stageActivity                    StageActivity[]
  stageFlowCurrentStage            StageFlow[]              @relation("CurrentStage")
  stageFlowNextStage               StageFlow[]              @relation("NextStage")
  stageRawMaterial                 StageRawMaterial[]

  @@map("Stage")
}

model ItemType {
  id              String                   @id @default(uuid())
  name            String                   @unique
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  failureRedirect FailureRedirect[]
  itemTypeStage   ItemType_Stage[]
  serviceProcess  Service_Process_Record[]
  stageFlow       StageFlow[]

  @@map("ItemType")
}

model StageActivity {
  id               String                  @id @default(uuid())
  serviceProcessId String?
  empId            String?
  stageId          String?
  status           ActivityStatus          @default(PENDING)
  isCurrent        Boolean                 @default(false)
  failureReason    FailureReason?
  remarks          String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  acceptedAt       DateTime?
  completedAt      DateTime?
  outcome          String?
  startedAt        DateTime?
  user             User?                   @relation(fields: [empId], references: [id])
  serviceProcess   Service_Process_Record? @relation(fields: [serviceProcessId], references: [id])
  stage            Stage?                  @relation(fields: [stageId], references: [id])

  @@index([empId], map: "StageActivity_empId_fkey")
  @@index([serviceProcessId], map: "StageActivity_serviceProcessId_fkey")
  @@index([stageId], map: "StageActivity_stageId_fkey")
  @@map("StageActivity")
}

model ItemType_Stage {
  id         String    @id @default(uuid())
  itemTypeId String?
  stageId    String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  itemType   ItemType? @relation(fields: [itemTypeId], references: [id])
  stage      Stage?    @relation(fields: [stageId], references: [id])

  @@index([itemTypeId], map: "ItemType_Stage_itemTypeId_fkey")
  @@index([stageId], map: "ItemType_Stage_stageId_fkey")
  @@map("ItemType_Stage")
}

model ItemRequestData {
  id                   String                  @id @default(uuid())
  serviceProcessId     String?
  isProcessRequest     Boolean                 @default(false)
  rawMaterialRequested Json?
  requestedTo          String?
  requestedBy          String?
  requestedAt          DateTime                @default(now())
  approved             Boolean?
  approvedBy           String?
  approvedAt           DateTime?
  materialGiven        Boolean?
  updatedAt            DateTime?               @updatedAt
  updatedBy            String?
  declined             Boolean?
  declinedAt           DateTime?
  declinedBy           String?
  declinedRemarks      String?
  warehouseId          String?
  materialRequested    Json?
  approvedByUser       User?                   @relation("ApprovedByUser", fields: [approvedBy], references: [id])
  declinedByUser       User?                   @relation("DeclinedByUser", fields: [declinedBy], references: [id])
  requestedByUser      User?                   @relation("RequestedByUser", fields: [requestedBy], references: [id])
  serviceProcess       Service_Process_Record? @relation(fields: [serviceProcessId], references: [id])
  updatedByUser        User?                   @relation("UpdatedByUser", fields: [updatedBy], references: [id])

  @@index([approvedBy], map: "ItemRequestData_approvedBy_fkey")
  @@index([declinedBy], map: "ItemRequestData_declinedBy_fkey")
  @@index([requestedBy], map: "ItemRequestData_requestedBy_fkey")
  @@index([serviceProcessId], map: "ItemRequestData_serviceProcessId_fkey")
  @@index([updatedBy], map: "ItemRequestData_updatedBy_fkey")
  @@map("ItemRequestData")
}

model DirectItemIssue {
  id                String                  @id @default(uuid())
  warehouseId       String?
  serviceProcessId  String?
  isProcessIssue    Boolean                 @default(false)
  rawMaterialIssued Json?
  issuedTo          String?
  issuedBy          String?
  issuedAt          DateTime                @default(now())
  remarks           String?
  updatedAt         DateTime?               @updatedAt
  updatedBy         String?
  department        String?
  issuedToName      String?
  materialIssued    Json?
  issuedByUser      User?                   @relation("IssuedByUser", fields: [issuedBy], references: [id])
  issuedToUser      User?                   @relation("IssuedToUser", fields: [issuedTo], references: [id])
  serviceProcess    Service_Process_Record? @relation(fields: [serviceProcessId], references: [id])
  updatedByUser     User?                   @relation("UpdatedByUser_DirectIssue", fields: [updatedBy], references: [id])

  @@index([issuedBy], map: "DirectItemIssue_issuedBy_fkey")
  @@index([issuedTo], map: "DirectItemIssue_issuedTo_fkey")
  @@index([serviceProcessId], map: "DirectItemIssue_serviceProcessId_fkey")
  @@index([updatedBy], map: "DirectItemIssue_updatedBy_fkey")
  @@map("DirectItemIssue")
}

model Service_Process_Record {
  id                   String                       @id @default(uuid())
  itemTypeId           String?
  serialNumber         String?
  stageId              String?
  initialStageId       String?
  restartedFromStageId String?
  status               ProcessStatus                @default(PENDING)
  createdAt            DateTime                     @default(now())
  createdBy            String?
  updatedAt            DateTime                     @updatedAt
  updatedBy            String?
  isRepaired           Boolean?
  quantity             Float?
  finalRemarks         String?
  finalStatus          String?
  isClosed             Boolean                      @default(false)
  completedAt          DateTime?
  itemName             String?
  productName          String?
  subItemName          String?
  disassembleSessionId String?
  disassembleStatus    String?
  isDisassemblePending Boolean?                     @default(false)
  warehouseId          String?
  directItemIssues     DirectItemIssue[]
  reusableItems        Disassemble_Reusable_Items[]
  itemRequestData      ItemRequestData[]
  serviceProcessUsage  ItemUsage[]
  createdUser          User?                        @relation("CreatedByUser", fields: [createdBy], references: [id])
  initialStage         Stage?                       @relation("InitialStage", fields: [initialStageId], references: [id])
  itemType             ItemType?                    @relation(fields: [itemTypeId], references: [id])
  restartedFromStage   Stage?                       @relation("RestartedFrom", fields: [restartedFromStageId], references: [id])
  stage                Stage?                       @relation(fields: [stageId], references: [id])
  updatedUser          User?                        @relation("UpdatedByUser", fields: [updatedBy], references: [id])
  stageActivity        StageActivity[]

  @@index([serialNumber])
  @@index([itemName])
  @@index([subItemName])
  @@index([createdAt])
  @@index([stageId])
  @@index([itemTypeId])
  @@index([status])
  @@index([createdBy], map: "Service_Process_Record_createdBy_fkey")
  @@index([initialStageId], map: "Service_Process_Record_initialStageId_fkey")
  @@index([restartedFromStageId], map: "Service_Process_Record_restartedFromStageId_fkey")
  @@index([updatedBy], map: "Service_Process_Record_updatedBy_fkey")
  @@map("Service_Process_Record")
}

model StageFlow {
  id             String    @id @default(uuid())
  itemTypeId     String?
  currentStageId String?
  nextStageId    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  productId      String?
  currentStage   Stage?    @relation("CurrentStage", fields: [currentStageId], references: [id])
  itemType       ItemType? @relation(fields: [itemTypeId], references: [id])
  nextStage      Stage?    @relation("NextStage", fields: [nextStageId], references: [id])
  product        Product?  @relation(fields: [productId], references: [id])

  @@index([currentStageId], map: "StageFlow_currentStageId_fkey")
  @@index([itemTypeId], map: "StageFlow_itemTypeId_fkey")
  @@index([nextStageId], map: "StageFlow_nextStageId_fkey")
  @@index([productId], map: "StageFlow_productId_fkey")
  @@map("StageFlow")
}

model FailureRedirect {
  id              String        @id @default(uuid())
  itemTypeId      String?
  failureReason   FailureReason
  redirectStageId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  productId       String?
  itemType        ItemType?     @relation(fields: [itemTypeId], references: [id])
  product         Product?      @relation(fields: [productId], references: [id])
  redirectStage   Stage?        @relation(fields: [redirectStageId], references: [id])

  @@index([itemTypeId], map: "FailureRedirect_itemTypeId_fkey")
  @@index([productId], map: "FailureRedirect_productId_fkey")
  @@index([redirectStageId], map: "FailureRedirect_redirectStageId_fkey")
  @@map("FailureRedirect")
}

model ItemUsage {
  id               String                  @id @default(uuid())
  serviceProcessId String?
  empId            String?
  rawMaterialId    String?
  quantityUsed     Float?
  unit             String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  itemId           String?
  itemType         ItemCategory?
  user             User?                   @relation(fields: [empId], references: [id])
  rawMaterial      RawMaterial?            @relation(fields: [rawMaterialId], references: [id])
  serviceProcess   Service_Process_Record? @relation(fields: [serviceProcessId], references: [id])

  @@index([empId], map: "ItemUsage_empId_fkey")
  @@index([rawMaterialId], map: "ItemUsage_rawMaterialId_fkey")
  @@index([serviceProcessId], map: "ItemUsage_serviceProcessId_fkey")
  @@map("ItemUsage")
}

model UserItemStock {
  id            String        @id @default(uuid())
  empId         String?
  rawMaterialId String?
  quantity      Float         @default(0)
  unit          String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  itemId        String?
  itemType      ItemCategory?
  user          User?         @relation(fields: [empId], references: [id])
  rawMaterial   RawMaterial?  @relation(fields: [rawMaterialId], references: [id])

  @@unique([empId, rawMaterialId])
  @@unique([empId, itemId, itemType])
  @@index([rawMaterialId], map: "UserItemStock_rawMaterialId_fkey")
  @@map("UserItemStock")
}

model Disassemble_Reusable_Items {
  id                   String                 @id @default(uuid())
  serviceProcessId     String
  empId                String?
  assembleEmpId        String?
  reusableItems        Json?
  remarks              String?
  createdAt            DateTime               @default(now())
  assembleEmp          User?                  @relation("AssembleEmployee", fields: [assembleEmpId], references: [id])
  disassembleEmp       User?                  @relation("DisassembleEmployee", fields: [empId], references: [id])
  serviceProcessRecord Service_Process_Record @relation(fields: [serviceProcessId], references: [id])

  @@index([assembleEmpId], map: "Disassemble_Reusable_Items_assembleEmpId_fkey")
  @@index([empId], map: "Disassemble_Reusable_Items_empId_fkey")
  @@index([serviceProcessId], map: "Disassemble_Reusable_Items_serviceProcessId_fkey")
}

model Item_Model {
  id              String            @id @default(uuid())
  model           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  itemRawMaterial ItemRawMaterial[]
}

model BOMEntry {
  id            String  @id @default(uuid())
  itemId        String?
  rawMaterialId String?
  quantity      Float?
}

model Product {
  id              String             @id @default(uuid())
  productName     String
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  failureRedirect FailureRedirect[]
  productItemMap  Product_Item_Map[]
  stageFlow       StageFlow[]
}

model Product_Item_Map {
  id        String   @id @default(uuid())
  productId String?
  itemId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  item      Item?    @relation(fields: [itemId], references: [id])
  product   Product? @relation(fields: [productId], references: [id])

  @@unique([productId, itemId], name: "unique_product_item")
  @@index([itemId], map: "Product_Item_Map_itemId_fkey")
}

model PanelMaster {
  id         String   @id @default(uuid())
  panelType  String?
  moduleType String?
  dcrType    String?
  wattage    String?
  hsnCode    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Company {
  id              String          @id @default(uuid())
  name            String
  companyCode     String?
  gstNumber       String?
  address         String?
  city            String?
  state           String?
  pincode         String?
  contactNumber   String?
  alternateNumber String?
  email           String?
  country         String?         @default("INDIA")
  currency        String?         @default("INR")
  createdBy       String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  isActive        Boolean?        @default(true)
  accountHolder   String?
  accountNumber   String?
  bankName        String?
  companyAadhaar  String?
  companyPanCard  String?
  ifscCode        String?
  bankAccounts    BankDetail[]
